        <span class="footer-manage" id="footerManage" title="Site management">Manage</span>
    </footer>


    <!-- Admin Login Modal -->
    <div class="admin-overlay" id="adminOverlay">
        <div class="admin-modal">
            <button class="admin-close" id="adminClose">&times;</button>
            <div class="admin-login" id="adminLogin">
                <h3>Site Management</h3>
                <input type="text" class="admin-input" id="adminUser" placeholder="Username" autocomplete="new-password">
                <input type="password" class="admin-input" id="adminPass" placeholder="Password" autocomplete="new-password">
                <button class="admin-btn" id="adminLoginBtn">Login</button>
                <div class="admin-error" id="adminError"></div>
            </div>
            <div class="admin-panel" id="adminPanel" style="display:none">
                <div class="admin-panel-header">
                    <h3>Site Management</h3>
                    <button class="admin-btn admin-btn-sm" id="adminLogout">Logout</button>
                </div>
                <div class="admin-section-label" style="display:flex;align-items:center;justify-content:space-between;">&#128293; Flip Votes <button class="admin-btn admin-btn-sm admin-btn-danger" id="adminResetVotes">Reset All Votes</button></div>
                <div class="admin-section-label">&#128161; Feedback Inbox</div>
                <div class="admin-feedback-list" id="adminFeedbackList">
                    <p class="admin-loading">Loading feedback...</p>
                </div>
                <div class="admin-section-label admin-section-label-mt" style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <div>&#128248; Pending Highlights</div>
                    <div style="display:flex;gap:8px;align-items:center;">
                        <button class="admin-btn admin-btn-sm" id="adminHighlightsRefresh">Refresh Pending</button>
