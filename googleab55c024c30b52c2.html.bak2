</main>

    <!-- Item Detail Modal -->
    <div class="modal-overlay" id="modalOverlay">
        <div class="modal" id="itemModal">
            <button class="modal-close" id="modalClose">&times;</button>
            <div class="modal-header">
                <img class="modal-icon" id="modalIcon" src="" alt="">
                <div class="modal-header-text">
                    <h2 class="modal-title" id="modalTitle"></h2>
                    <p class="modal-examine" id="modalExamine"></p>
                </div>
                <button class="modal-fav-btn" id="modalFavBtn" title="Toggle Favorite">
                    <svg class="fav-icon-outline" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    <svg class="fav-icon-filled" viewBox="0 0 24 24" fill="currentColor" width="24" height="24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                </button>
            </div>
            <div class="modal-body">
                <div class="modal-tags" id="modalTags"></div>
                <div class="modal-prices">
                    <div class="modal-price-card buy">
                        <span class="price-label">Buy Price (Instant)</span>
                        <span class="price-value" id="modalBuyPrice">-</span>
                        <span class="price-time" id="modalBuyTime">-</span>
                    </div>
                    <div class="modal-price-card sell">
                        <span class="price-label">Sell Price (Instant)</span>
                        <span class="price-value" id="modalSellPrice">-</span>
                        <span class="price-time" id="modalSellTime">-</span>
                    </div>
                    <div class="modal-price-card margin">
                        <span class="price-label">Margin</span>
                        <span class="price-value" id="modalMargin">-</span>
                        <span class="price-time" id="modalMarginPct">-</span>
                    </div>
                </div>
                <div class="modal-details">
                    <div class="detail-row">
                        <span>GE Tax (2%)</span>
                        <span id="modalGeTax" style="color: var(--red)">-</span>
                    </div>
                    <div class="detail-row">
                        <span>Buy Limit (4h)</span>
                        <span id="modalLimit">-</span>
                    </div>
                    <div class="detail-row">
                        <span>Buy Limit Profit</span>
                        <span id="modalLimitProfit">-</span>
                    </div>
                </div>
                <!-- Flip Sentiment Vote -->
                <div class="flip-vote-section" id="flipVoteSection">
                    <div class="flip-vote-label">Is this a good flip?</div>
                    <div class="flip-vote-buttons">
                        <button class="flip-vote-btn flip-vote-up" id="flipVoteUp" title="Good flip">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M1 21h4V9H1v12zm22-11c0-1.1-.9-2-2-2h-6.31l.95-4.57.03-.32c0-.41-.17-.79-.44-1.06L14.17 1 7.59 7.59C7.22 7.95 7 8.45 7 9v10c0 1.1.9 2 2 2h9c.83 0 1.54-.5 1.84-1.22l3.02-7.05c.09-.23.14-.47.14-.73v-2z"/></svg>
                            <span class="flip-vote-count" id="flipVoteUpCount">0</span>
                        </button>
                        <div class="flip-vote-bar-wrap" id="flipVoteBarWrap">
                            <div class="flip-vote-bar-up" id="flipVoteBarUp"></div>
                            <div class="flip-vote-bar-down" id="flipVoteBarDown"></div>
                        </div>
                        <button class="flip-vote-btn flip-vote-down" id="flipVoteDown" title="Bad flip">
                            <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M15 3H6c-.83 0-1.54.5-1.84 1.22l-3.02 7.05c-.09.23-.14.47-.14.73v2c0 1.1.9 2 2 2h6.31l-.95 4.57-.03.32c0 .41.17.79.44 1.06L10.83 23l6.59-6.59c.36-.36.58-.86.58-1.41V5c0-1.1-.9-2-2-2zm4 0v12h4V3h-4z"/></svg>
                            <span class="flip-vote-count" id="flipVoteDownCount">0</span>
                        </button>
                    </div>
                    <div class="flip-vote-meta" id="flipVoteMeta"></div>
                </div>

                <!-- Price & Volume History -->
                <div class="history-section">
                    <div class="history-header">
                        <h3>Price & Volume History</h3>
                        <div class="history-tabs">
                            <button class="history-tab active" data-period="5m">24h</button>
                            <button class="history-tab" data-period="1h">7d</button>
                            <button class="history-tab" data-period="24h">30d</button>
                            <button class="history-tab" data-period="1y">1y</button>
                        </div>
                    </div>
                    <div class="chart-container" style="display:none;">
                        <canvas id="priceChart"></canvas>
                    </div>
                    <div class="chart-container volume-chart" style="display:none;">
                        <canvas id="volumeChart"></canvas>
                    </div>
                    <div class="history-loading" id="historyLoading" style="display:none;">
                        <div class="loading-spinner small"></div>
                        <span>Loading history...</span>
                    </div>
                    <div class="history-error" id="historyError" style="display:none;">
                        <span>No history data available for this item.</span>
                    </div>
                </div>

                <a class="wiki-link" id="modalWikiLink" href="#" target="_blank" rel="noopener">
                    View on OSRS Wiki ?
                </a>
            </div>
        </div>
    </div>

    <!-- Back to Top -->
    <button class="back-to-top" id="backToTop" title="Back to top">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="20" height="20"><path d="m18 15-6-6-6 6"/></svg>
    </button>

